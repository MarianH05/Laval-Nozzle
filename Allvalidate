#!/usr/bin/env bash
set -euo pipefail

cd "$(dirname "$0")"

ROOT_DIR="$PWD"
DEFAULT_CASES=(cases/subsonic cases/choked cases/internal_shock)

case_path() {
    case "$1" in
        cases/*) printf '%s\n' "$1" ;;
        *) printf 'cases/%s\n' "$1" ;;
    esac
}

validate_case() {
    local case_dir="$1"
    local case_name
    local abs_case_dir
    local extra_args=()

    abs_case_dir="$ROOT_DIR/$case_dir"
    case_name="$(basename "$case_dir")"

    if [[ ! -d "$abs_case_dir" ]]; then
        echo "Case not found: $case_dir" >&2
        exit 1
    fi

    if [[ ! -f "$abs_case_dir/system/controlDict" ]]; then
        echo "Not an OpenFOAM case: $case_dir" >&2
        exit 1
    fi

    if ! find "$abs_case_dir" -maxdepth 2 -type f -path '*/rho' | grep -q .; then
        echo "No solved time directory with rho/U/p/T found for $case_dir."
        echo "Allvalidate reads existing outputs only; run ./Allrun $case_dir when solver regeneration is intended."
        exit 0
    fi

    if [[ "$case_dir" == cases/mesh_study/* ]]; then
        extra_args+=(--skip-pressure-study)
    fi

    if [[ "$case_name" == "subsonic" ]]; then
        extra_args+=(--subsonic)
    fi

    echo "Validating existing outputs for $case_dir"
    python3 "$ROOT_DIR/scripts/validate_case.py" \
        --case "$abs_case_dir" \
        --summary "$ROOT_DIR/docs/validation_${case_name}.md" \
        --images-dir "$ROOT_DIR/docs/images/$case_name" \
        --area-images-dir "$ROOT_DIR/docs/images" \
        --study-csv "$ROOT_DIR/docs/pressure_ratio_study.csv" \
        --study-markdown "$ROOT_DIR/docs/pressure_ratio_study.md" \
        --centerline-output "$abs_case_dir/postProcessing/centerline/centerline_latest.csv" \
        "${extra_args[@]}"
}

if [[ "$#" -eq 0 ]]; then
    set -- all
fi

for arg in "$@"; do
    if [[ "$arg" == "all" ]]; then
        for case_dir in "${DEFAULT_CASES[@]}"; do
            validate_case "$case_dir"
        done
    else
        validate_case "$(case_path "$arg")"
    fi
done
