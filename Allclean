#!/usr/bin/env bash
set -euo pipefail

cd "$(dirname "$0")"

ROOT_DIR="$PWD"

usage() {
    cat <<'EOF'
Allclean removes only safe temporary files.

It does not delete:
  - OpenFOAM time directories
  - 0/ initial-condition directories
  - postProcessing outputs
  - solver logs
  - case dictionaries

Use ./AllcleanResults for confirmed deletion of generated results.
EOF
}

usage

find "$ROOT_DIR" -type d -name __pycache__ -prune -exec rm -rf {} +
find "$ROOT_DIR" -type f -name '*.pyc' -delete
find "$ROOT_DIR/report" -maxdepth 1 -type f \
    \( -name '*.aux' -o -name '*.log' -o -name '*.out' -o -name '*.toc' \
       -o -name '*.fls' -o -name '*.fdb_latexmk' -o -name '*.synctex.gz' \) \
    -delete

echo "Safe cleanup complete."
