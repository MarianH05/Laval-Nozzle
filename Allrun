#!/bin/sh
cd "${0%/*}" || exit 1

ROOT_DIR="$PWD"
DEFAULT_CASES="cases/subsonic cases/choked cases/internal_shock"

. "${WM_PROJECT_DIR:?}/bin/tools/RunFunctions"

case_path()
{
    case "$1" in
        cases/*) printf '%s\n' "$1" ;;
        *)       printf 'cases/%s\n' "$1" ;;
    esac
}

run_case()
{
    CASE="$1"
    CASE_NAME="$(basename "$CASE")"

    if [ ! -d "$CASE" ]; then
        echo "Case not found: $CASE" >&2
        exit 1
    fi

    echo "Running $CASE"
    (
        cd "$CASE" || exit 1

        runApplication blockMesh
        runApplication checkMesh
        runApplication rhoCentralFoam

        if rhoCentralFoam -postProcess -func MachNo -latestTime > log.postProcess.MachNo 2>&1
        then
            echo "Mach number field written at latest time for $CASE"
        else
            echo "MachNo post-processing skipped for $CASE; see log.postProcess.MachNo"
        fi
    )

    python3 "$ROOT_DIR/scripts/validate_case.py" \
        --case "$ROOT_DIR/$CASE" \
        --summary "$ROOT_DIR/docs/validation_${CASE_NAME}.md" \
        --images-dir "$ROOT_DIR/docs/images/$CASE_NAME" \
        --area-images-dir "$ROOT_DIR/docs/images" \
        --study-csv "$ROOT_DIR/docs/pressure_ratio_study.csv" \
        --study-markdown "$ROOT_DIR/docs/pressure_ratio_study.md" \
        --centerline-output "$ROOT_DIR/$CASE/postProcessing/centerline/centerline_latest.csv" \
        $(case "$CASE" in cases/mesh_study/*) printf '%s\n' "--skip-pressure-study" ;; esac) \
        $([ "$CASE_NAME" = "subsonic" ] && printf '%s\n' "--subsonic")
}

if [ "$#" -eq 0 ]; then
    set -- all
fi

for ARG in "$@"; do
    if [ "$ARG" = "all" ]; then
        for CASE in $DEFAULT_CASES; do
            run_case "$CASE"
        done
    else
        run_case "$(case_path "$ARG")"
    fi
done
