# OpenFOAM generated time directories
cases/**/[0-9]*/
cases/**/[0-9]*.[0-9]*/
!cases/**/0/
!cases/**/0/**

# OpenFOAM generated outputs
cases/**/log*
cases/**/postProcessing/
cases/**/processor*/

# Generated blockMesh/polyMesh files
cases/**/constant/polyMesh/points
cases/**/constant/polyMesh/faces
cases/**/constant/polyMesh/owner
cases/**/constant/polyMesh/neighbour
cases/**/constant/polyMesh/boundary

# Python cache
__pycache__/
*.pyc

# LaTeX auxiliary files
report/*.aux
report/*.log
report/*.out
report/*.toc
report/*.fls
report/*.fdb_latexmk
report/*.synctex.gz

# Temporary editor and OS files
*~
*.swp
*.swo
.DS_Store
